@inherits LocalizedComponentBase
@inject IHttpClientFactory HttpClientFactory

@if (artists is null)
{
    <p><em>@L["Common.Loading"]</em></p>
}
else if (loadError is not null)
{
    <div class="alert alert-danger">@loadError</div>
}
else
{
    @foreach (var group in artists.GroupBy(a => a.Genre ?? "other").OrderBy(g => g.Key))
    {
        <div class="mb-3">
            <div class="text-muted small text-uppercase mb-1" style="letter-spacing:0.08em;">@group.Key</div>
            <div class="d-flex flex-wrap gap-2">
                @foreach (var a in group.OrderBy(x => x.Name))
                {
                    var selected = SelectedIds.Contains(a.Id);
                    var cls = selected ? "btn btn-primary btn-sm" : "btn btn-outline-secondary btn-sm";
                    <button type="button" class="@cls" @onclick="() => Toggle(a.Id)" disabled="@Disabled">
                        @a.Name
                    </button>
                }
            </div>
        </div>
    }
}

@code {
    [Parameter, EditorRequired] public HashSet<Guid> SelectedIds { get; set; } = [];
    [Parameter] public EventCallback OnChanged { get; set; }
    [Parameter] public bool Disabled { get; set; }

    private ArtistDto[]? artists;
    private string? loadError;

    protected override async Task OnInitializedAsync()
    {
        base.OnInitialized();
        try
        {
            var http = HttpClientFactory.CreateClient("api");
            artists = await http.GetFromJsonAsync<ArtistDto[]>("/api/artists");
        }
        catch (Exception ex)
        {
            loadError = ex.Message;
        }
    }

    private async Task Toggle(Guid id)
    {
        if (!SelectedIds.Add(id))
        {
            SelectedIds.Remove(id);
        }
        await OnChanged.InvokeAsync();
    }
}
