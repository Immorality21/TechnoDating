@page "/festivals"
@attribute [Authorize]
@inherits LocalizedComponentBase
@inject IHttpClientFactory HttpClientFactory

<h1>@L["Festivals.Heading"]</h1>

@if (festivals is null)
{
    <p><em>@L["Common.Loading"]</em></p>
}
else if (loadError is not null)
{
    <div class="alert alert-danger">
        <strong>@L["Common.Error.ApiUnreachable"]</strong>
        <div><code>@loadError</code></div>
        <div class="mt-2">@L["Common.Error.ApiUnreachableHint"]</div>
    </div>
}
else
{
    <table class="table align-middle">
        <thead>
            <tr>
                <th>@L["Festivals.Col.Date"]</th>
                <th>@L["Festivals.Col.Festival"]</th>
                <th>@L["Festivals.Col.City"]</th>
                <th>@L["Festivals.Col.Lineup"]</th>
                <th class="text-end">@L["Festivals.Col.Going"]</th>
                <th class="text-end">@L["Festivals.Col.YourArtists"]</th>
                <th>@L["Festivals.Col.YourStatus"]</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var f in festivals)
            {
                <tr>
                    <td>@f.Date.ToString("ddd d MMM yyyy", System.Globalization.CultureInfo.CurrentUICulture)</td>
                    <td>
                        <a href="@($"/festivals/{f.Id}")"><strong>@f.Name</strong></a>
                        <div class="text-muted small">@f.Venue</div>
                    </td>
                    <td>@f.City</td>
                    <td>@string.Join(" · ", f.HeadlineArtists.Select(a => a.Name))</td>
                    <td class="text-end">@f.AttendingCount</td>
                    <td class="text-end">
                        @if (f.MatchingArtistsCount > 0)
                        {
                            var key = f.MatchingArtistsCount == 1 ? "Festivals.ArtistsMatch.One" : "Festivals.ArtistsMatch.Many";
                            <span class="badge bg-success">@string.Format(L[key], f.MatchingArtistsCount)</span>
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>
                    <td>
                        <select class="form-select form-select-sm" value="@(f.MyStatus?.ToString() ?? "")"
                                @onchange="@(async e => await OnStatusChanged(f.Id, e.Value as string))">
                            <option value="">@L["Common.None"]</option>
                            <option value="Interested">@L["Attendance.Status.Interested"]</option>
                            <option value="Going">@L["Attendance.Status.Going"]</option>
                            <option value="Ticketed">@L["Attendance.Status.Ticketed"]</option>
                        </select>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private FestivalDto[]? festivals;
    private string? loadError;

    protected override async Task OnInitializedAsync()
    {
        base.OnInitialized();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            var http = HttpClientFactory.CreateClient("api");
            festivals = await http.GetFromJsonAsync<FestivalDto[]>("/api/festivals");
        }
        catch (Exception ex)
        {
            loadError = ex.Message;
        }
    }

    private async Task OnStatusChanged(Guid festivalId, string? raw)
    {
        var http = HttpClientFactory.CreateClient("api");
        try
        {
            if (string.IsNullOrEmpty(raw))
            {
                await http.DeleteAsync($"/api/attendance/{festivalId}");
            }
            else if (Enum.TryParse<AttendanceStatus>(raw, out var status))
            {
                await http.PutAsJsonAsync($"/api/attendance/{festivalId}", new UpsertAttendanceDto(status));
            }
            await LoadAsync();
        }
        catch (Exception ex)
        {
            loadError = ex.Message;
        }
    }
}
