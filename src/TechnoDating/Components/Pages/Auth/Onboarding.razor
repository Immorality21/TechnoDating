@page "/onboarding"
@attribute [Authorize]
@layout MainLayout
@inherits LocalizedComponentBase
@inject IAuthStateService Auth
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav

<h1>@L["Onboarding.Heading"]</h1>

<p>@L["Onboarding.Intro"]</p>

<EditForm Model="this" OnValidSubmit="Submit">
    <div class="mb-3">
        <label for="displayName" class="form-label">@L["Onboarding.DisplayName"]</label>
        <input id="displayName" type="text" class="form-control" @bind="displayName" maxlength="100" disabled="@busy" />
    </div>

    <div class="mb-3">
        <label for="dob" class="form-label">@L["Onboarding.DateOfBirth"]</label>
        <input id="dob" type="date" class="form-control" @bind="dateOfBirth" disabled="@busy" />
    </div>

    <div class="mb-3">
        <label for="gender" class="form-label">@L["Onboarding.Gender"]</label>
        <select id="gender" class="form-select" @bind="gender" disabled="@busy">
            <option value="">@L["Onboarding.Gender.Select"]</option>
            <option value="female">@L["Onboarding.Gender.Female"]</option>
            <option value="male">@L["Onboarding.Gender.Male"]</option>
            <option value="non-binary">@L["Onboarding.Gender.NonBinary"]</option>
            <option value="other">@L["Onboarding.Gender.Other"]</option>
        </select>
    </div>

    <div class="mb-3">
        <label for="city" class="form-label">@L["Onboarding.City"]</label>
        <input id="city" type="text" class="form-control" @bind="city" maxlength="100" placeholder="Amsterdam" disabled="@busy" />
    </div>

    <div class="mb-3">
        <label class="form-label">@L["Onboarding.Artists.Heading"]</label>
        <div class="text-muted small mb-2">@L["Onboarding.Artists.Hint"]</div>
        <ArtistPicker SelectedIds="selectedArtistIds" OnChanged="StateHasChanged" Disabled="busy" />
    </div>

    @if (errorMessage is not null)
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    <button type="submit" class="btn btn-primary" disabled="@(!CanSubmit || busy)">
        @(busy ? L["Common.Saving"] : L["Onboarding.SubmitButton"])
    </button>
</EditForm>

@code {
    private string displayName = string.Empty;
    private DateTime? dateOfBirth;
    private string gender = string.Empty;
    private string city = string.Empty;
    private HashSet<Guid> selectedArtistIds = [];
    private bool busy;
    private string? errorMessage;

    private bool CanSubmit =>
        !string.IsNullOrWhiteSpace(displayName)
        && dateOfBirth.HasValue
        && !string.IsNullOrWhiteSpace(gender)
        && !string.IsNullOrWhiteSpace(city);

    private async Task Submit()
    {
        if (!CanSubmit)
        {
            return;
        }
        busy = true;
        errorMessage = null;
        try
        {
            var dto = new UpdateProfileDto(
                displayName.Trim(),
                DateOnly.FromDateTime(dateOfBirth!.Value),
                gender,
                Bio: null,
                city.Trim(),
                TopArtistIds: selectedArtistIds.ToList(),
                Longitude: null,
                Latitude: null);

            var http = HttpClientFactory.CreateClient("api");
            var response = await http.PutAsJsonAsync("/api/users/me", dto);
            if (!response.IsSuccessStatusCode)
            {
                errorMessage = L["Common.Error.SaveFailed"];
                return;
            }
            var updated = await response.Content.ReadFromJsonAsync<UserProfileDto>();
            if (updated is null)
            {
                errorMessage = L["Common.Error.SaveFailed"];
                return;
            }
            await Auth.SetCurrentUserAsync(updated);
            Nav.NavigateTo("/", replace: true);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            busy = false;
        }
    }
}
