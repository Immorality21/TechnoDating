@page "/onboarding"
@attribute [Authorize]
@layout MainLayout
@inject IAuthStateService Auth
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav

<h1>Welcome — tell us a bit about you</h1>

<p>These help us find people you'll actually vibe with. You can fill in more on your profile later.</p>

<EditForm Model="this" OnValidSubmit="Submit">
    <div class="mb-3">
        <label for="displayName" class="form-label">Display name</label>
        <input id="displayName" type="text" class="form-control" @bind="displayName" maxlength="100" disabled="@busy" />
    </div>

    <div class="mb-3">
        <label for="dob" class="form-label">Date of birth</label>
        <input id="dob" type="date" class="form-control" @bind="dateOfBirth" disabled="@busy" />
    </div>

    <div class="mb-3">
        <label for="gender" class="form-label">Gender</label>
        <select id="gender" class="form-select" @bind="gender" disabled="@busy">
            <option value="">Select…</option>
            <option value="female">Female</option>
            <option value="male">Male</option>
            <option value="non-binary">Non-binary</option>
            <option value="other">Other</option>
        </select>
    </div>

    <div class="mb-3">
        <label for="city" class="form-label">City</label>
        <input id="city" type="text" class="form-control" @bind="city" maxlength="100" placeholder="Amsterdam" disabled="@busy" />
    </div>

    @if (errorMessage is not null)
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    <button type="submit" class="btn btn-primary" disabled="@(!CanSubmit || busy)">
        @(busy ? "Saving…" : "Continue")
    </button>
</EditForm>

@code {
    private string displayName = string.Empty;
    private DateTime? dateOfBirth;
    private string gender = string.Empty;
    private string city = string.Empty;
    private bool busy;
    private string? errorMessage;

    private bool CanSubmit =>
        !string.IsNullOrWhiteSpace(displayName)
        && dateOfBirth.HasValue
        && !string.IsNullOrWhiteSpace(gender)
        && !string.IsNullOrWhiteSpace(city);

    private async Task Submit()
    {
        if (!CanSubmit)
        {
            return;
        }
        busy = true;
        errorMessage = null;
        try
        {
            var dto = new UpdateProfileDto(
                displayName.Trim(),
                DateOnly.FromDateTime(dateOfBirth!.Value),
                gender,
                Bio: null,
                city.Trim(),
                TopArtists: [],
                Longitude: null,
                Latitude: null);

            var http = HttpClientFactory.CreateClient("api");
            var response = await http.PutAsJsonAsync("/api/users/me", dto);
            if (!response.IsSuccessStatusCode)
            {
                errorMessage = "Couldn't save. Please try again.";
                return;
            }
            var updated = await response.Content.ReadFromJsonAsync<UserProfileDto>();
            if (updated is null)
            {
                errorMessage = "Unexpected response. Please try again.";
                return;
            }
            await Auth.SetCurrentUserAsync(updated);
            Nav.NavigateTo("/", replace: true);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            busy = false;
        }
    }
}
