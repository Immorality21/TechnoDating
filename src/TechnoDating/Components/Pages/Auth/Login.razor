@page "/login"
@layout MainLayout
@inherits LocalizedComponentBase
@inject IAuthStateService Auth
@inject NavigationManager Nav

<h1>@L["Auth.Login.Heading"]</h1>

<p>@L["Auth.Login.Intro"]</p>

<EditForm Model="this" OnValidSubmit="Submit">
    <div class="mb-3">
        <label for="phone" class="form-label">@L["Auth.Login.PhoneLabel"]</label>
        <input id="phone" type="tel" class="form-control" @bind="phoneNumber" placeholder="+31600000000" autocomplete="tel" disabled="@busy" />
    </div>

    @if (errorMessage is not null)
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    <button type="submit" class="btn btn-primary" disabled="@(busy || string.IsNullOrWhiteSpace(phoneNumber))">
        @(busy ? L["Common.Sending"] : L["Auth.Login.SubmitButton"])
    </button>
</EditForm>

@code {
    private string phoneNumber = "+31";
    private bool busy;
    private string? errorMessage;

    private async Task Submit()
    {
        busy = true;
        errorMessage = null;
        try
        {
            var trimmed = phoneNumber?.Trim() ?? string.Empty;
            var ok = await Auth.RequestOtpAsync(trimmed);
            if (!ok)
            {
                errorMessage = L["Auth.Login.Error.SendFailed"];
                return;
            }
            Nav.NavigateTo($"/verify-otp?phone={Uri.EscapeDataString(trimmed)}");
        }
        finally
        {
            busy = false;
        }
    }
}
