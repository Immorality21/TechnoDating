@page "/festivals/{FestivalId:guid}"
@attribute [Authorize]
@inherits LocalizedComponentBase
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav

@if (loadError is not null)
{
    <div class="alert alert-danger">
        <div><code>@loadError</code></div>
    </div>
}
else if (festival is null)
{
    <p><em>@L["Common.Loading"]</em></p>
}
else
{
    <p class="mb-2"><a href="/festivals">@L["Festivals.AllFestivalsLink"]</a></p>
    <h1>@festival.Name</h1>
    <p class="text-muted">
        @festival.Date.ToString("dddd d MMMM yyyy", System.Globalization.CultureInfo.CurrentUICulture) · @festival.City · @festival.Venue
    </p>

    <div class="mb-3">
        <strong>@L["Festivals.Col.Lineup"]:</strong> @string.Join(" · ", festival.HeadlineArtists.Select(a => a.Name))
        @if (festival.MatchingArtistsCount > 0)
        {
            var key = festival.MatchingArtistsCount == 1 ? "Festivals.ArtistsMatch.One" : "Festivals.ArtistsMatch.Many";
            <span class="badge bg-success ms-2">@string.Format(L[key], festival.MatchingArtistsCount)</span>
        }
    </div>

    <div class="mb-3 d-flex align-items-center gap-2">
        <span><strong>@L["Festivals.MyStatusLabel"]</strong></span>
        <select class="form-select form-select-sm" style="max-width:220px" value="@(festival.MyStatus?.ToString() ?? "")"
                @onchange="@(async e => await OnStatusChanged(e.Value as string))">
            <option value="">@L["Attendance.Status.None"]</option>
            <option value="Interested">@L["Attendance.Status.Interested"]</option>
            <option value="Going">@L["Attendance.Status.Going"]</option>
            <option value="Ticketed">@L["Attendance.Status.Ticketed"]</option>
        </select>
        <span class="text-muted small">@string.Format(L["Festivals.GoingCount"], festival.AttendingCount)</span>
    </div>

    <h2 class="mt-4">@L["Festivals.WhosGoing"]</h2>
    @if (attendees is null)
    {
        <p><em>@L["Common.Loading"]</em></p>
    }
    else if (attendees.Length == 0)
    {
        <p class="text-muted">@L["Festivals.WhosGoing.Empty"]</p>
    }
    else
    {
        <div class="row g-3">
            @foreach (var a in attendees)
            {
                <div class="col-md-6">
                    <div class="card h-100">
                        <div class="card-body">
                            <div class="d-flex align-items-center gap-3 mb-2">
                                <Avatar DisplayName="@a.DisplayName" UserId="@a.Id" PhotoUrl="@a.PrimaryPhotoUrl" Size="52px" />
                                <div>
                                    <h5 class="card-title mb-0">@a.DisplayName, @a.Age</h5>
                                    <h6 class="card-subtitle text-muted">@a.City</h6>
                                </div>
                            </div>
                            <p class="mb-0"><strong>@L["Matches.Card.TopArtists"]</strong> @string.Join(" · ", a.TopArtists.Select(x => x.Name))</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}

@code {
    [Parameter] public Guid FestivalId { get; set; }

    private FestivalDto? festival;
    private MatchProfileDto[]? attendees;
    private string? loadError;

    protected override async Task OnInitializedAsync()
    {
        base.OnInitialized();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            var http = HttpClientFactory.CreateClient("api");
            var list = await http.GetFromJsonAsync<FestivalDto[]>("/api/festivals");
            festival = list?.FirstOrDefault(f => f.Id == FestivalId);
            if (festival is null)
            {
                loadError = L["Common.Error.LoadFailed"];
                return;
            }
            attendees = await http.GetFromJsonAsync<MatchProfileDto[]>($"/api/festivals/{FestivalId}/attendees");
        }
        catch (Exception ex)
        {
            loadError = ex.Message;
        }
    }

    private async Task OnStatusChanged(string? raw)
    {
        var http = HttpClientFactory.CreateClient("api");
        try
        {
            if (string.IsNullOrEmpty(raw))
            {
                await http.DeleteAsync($"/api/attendance/{FestivalId}");
            }
            else if (Enum.TryParse<AttendanceStatus>(raw, out var status))
            {
                await http.PutAsJsonAsync($"/api/attendance/{FestivalId}", new UpsertAttendanceDto(status));
            }
            await LoadAsync();
        }
        catch (Exception ex)
        {
            loadError = ex.Message;
        }
    }
}
