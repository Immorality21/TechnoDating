@page "/me"
@attribute [Authorize]
@layout MainLayout
@inherits LocalizedComponentBase
@inject IAuthStateService Auth
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Nav

<h1>@L["Profile.Heading"]</h1>

@if (profile is null)
{
    <p><em>@L["Common.Loading"]</em></p>
}
else
{
    <EditForm Model="this" OnValidSubmit="Save">
        <div class="mb-3">
            <label class="form-label">@L["Profile.Phone"]</label>
            <input class="form-control" value="@profile.PhoneNumber" disabled />
        </div>

        <div class="mb-3">
            <label for="displayName" class="form-label">@L["Onboarding.DisplayName"]</label>
            <input id="displayName" class="form-control" @bind="displayName" maxlength="100" disabled="@busy" />
        </div>

        <div class="mb-3">
            <label for="dob" class="form-label">@L["Onboarding.DateOfBirth"]</label>
            <input id="dob" type="date" class="form-control" @bind="dateOfBirth" disabled="@busy" />
        </div>

        <div class="mb-3">
            <label for="gender" class="form-label">@L["Onboarding.Gender"]</label>
            <select id="gender" class="form-select" @bind="gender" disabled="@busy">
                <option value="">@L["Onboarding.Gender.Select"]</option>
                <option value="female">@L["Onboarding.Gender.Female"]</option>
                <option value="male">@L["Onboarding.Gender.Male"]</option>
                <option value="non-binary">@L["Onboarding.Gender.NonBinary"]</option>
                <option value="other">@L["Onboarding.Gender.Other"]</option>
            </select>
        </div>

        <div class="mb-3">
            <label for="city" class="form-label">@L["Onboarding.City"]</label>
            <input id="city" class="form-control" @bind="city" maxlength="100" disabled="@busy" />
        </div>

        <div class="mb-3">
            <label for="bio" class="form-label">@L["Profile.Bio"]</label>
            <textarea id="bio" class="form-control" rows="3" @bind="bio" maxlength="2000" disabled="@busy"></textarea>
        </div>

        <div class="mb-3">
            <label class="form-label">@L["Profile.Photos.Heading"]</label>
            <PhotoGallery Photos="profile.Photos" OnChanged="ReloadPhotosAsync" />
        </div>

        <div class="mb-3">
            <label class="form-label">@L["Profile.TopArtists"]</label>
            <ArtistPicker SelectedIds="selectedArtistIds" OnChanged="StateHasChanged" Disabled="busy" />
        </div>

        <div class="mb-3">
            <label for="language" class="form-label">@L["Profile.Language"]</label>
            <select id="language" class="form-select" value="@Language.CurrentLanguage"
                    style="max-width:240px"
                    @onchange="@(async e => await Language.SetLanguageAsync(e.Value as string ?? "en"))"
                    disabled="@busy">
                @foreach (var lang in Language.AvailableLanguages)
                {
                    <option value="@lang.Code">@lang.DisplayName</option>
                }
            </select>
        </div>

        @if (message is not null)
        {
            <div class="alert alert-info">@message</div>
        }

        <button type="submit" class="btn btn-primary" disabled="@(!CanSubmit || busy)">
            @(busy ? L["Common.Saving"] : L["Common.Save"])
        </button>
        <button type="button" class="btn btn-outline-danger ms-2" @onclick="Logout" disabled="@busy">
            @L["Common.Logout"]
        </button>
    </EditForm>
}

@code {
    private UserProfileDto? profile;
    private string displayName = string.Empty;
    private DateTime? dateOfBirth;
    private string gender = string.Empty;
    private string city = string.Empty;
    private string bio = string.Empty;
    private HashSet<Guid> selectedArtistIds = [];
    private bool busy;
    private string? message;

    private bool CanSubmit =>
        !string.IsNullOrWhiteSpace(displayName)
        && dateOfBirth.HasValue
        && !string.IsNullOrWhiteSpace(gender)
        && !string.IsNullOrWhiteSpace(city);

    protected override async Task OnInitializedAsync()
    {
        base.OnInitialized();
        var http = HttpClientFactory.CreateClient("api");
        try
        {
            profile = await http.GetFromJsonAsync<UserProfileDto>("/api/users/me");
            if (profile is not null)
            {
                displayName = profile.DisplayName ?? string.Empty;
                dateOfBirth = profile.DateOfBirth?.ToDateTime(TimeOnly.MinValue);
                gender = profile.Gender ?? string.Empty;
                city = profile.City ?? string.Empty;
                bio = profile.Bio ?? string.Empty;
                selectedArtistIds = profile.TopArtists.Select(a => a.Id).ToHashSet();
            }
        }
        catch (Exception ex)
        {
            message = ex.Message;
        }
    }

    private async Task Save()
    {
        if (!CanSubmit)
        {
            return;
        }
        busy = true;
        message = null;
        try
        {
            var dto = new UpdateProfileDto(
                displayName.Trim(),
                DateOnly.FromDateTime(dateOfBirth!.Value),
                gender,
                string.IsNullOrWhiteSpace(bio) ? null : bio.Trim(),
                city.Trim(),
                selectedArtistIds.ToList());

            var http = HttpClientFactory.CreateClient("api");
            var response = await http.PutAsJsonAsync("/api/users/me", dto);
            if (!response.IsSuccessStatusCode)
            {
                message = L["Common.Error.SaveFailed"];
                return;
            }
            var updated = await response.Content.ReadFromJsonAsync<UserProfileDto>();
            if (updated is not null)
            {
                profile = updated;
                selectedArtistIds = updated.TopArtists.Select(a => a.Id).ToHashSet();
                await Auth.SetCurrentUserAsync(updated);
                message = L["Common.Saved"];
            }
        }
        catch (Exception ex)
        {
            message = ex.Message;
        }
        finally
        {
            busy = false;
        }
    }

    private async Task ReloadPhotosAsync()
    {
        try
        {
            var http = HttpClientFactory.CreateClient("api");
            var refreshed = await http.GetFromJsonAsync<UserProfileDto>("/api/users/me");
            if (refreshed is not null)
            {
                profile = refreshed;
                await Auth.SetCurrentUserAsync(refreshed);
            }
        }
        catch (Exception ex)
        {
            message = ex.Message;
        }
    }

    private async Task Logout()
    {
        await Auth.LogoutAsync();
        Nav.NavigateTo("/login", replace: true);
    }
}
