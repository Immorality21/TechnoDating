@page "/matches"
@inject HttpClient Http

<h1>Your matches</h1>

<p>Pulled live from <code>GET /api/matches</code>.</p>

@if (matches is null)
{
    <p><em>Loading…</em></p>
}
else if (loadError is not null)
{
    <div class="alert alert-danger">
        <strong>Couldn't reach the API.</strong>
        <div><code>@loadError</code></div>
        <div class="mt-2">Make sure <code>TechnoDating.Api</code> is running on <code>http://localhost:5000</code>.</div>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var m in matches)
        {
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title mb-1">@m.DisplayName, @m.Age</h5>
                        <h6 class="card-subtitle text-muted mb-3">
                            @m.City · @m.DistanceKm.ToString("0.#") km away
                        </h6>
                        <p class="mb-1"><strong>Top artists:</strong> @string.Join(" · ", m.TopArtists)</p>
                        <p class="mb-0"><strong>Shared festivals:</strong> @string.Join(" · ", m.CommonFestivals)</p>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private MatchProfileDto[]? matches;
    private string? loadError;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            matches = await Http.GetFromJsonAsync<MatchProfileDto[]>("/api/matches");
        }
        catch (Exception ex)
        {
            loadError = ex.Message;
        }
    }
}
