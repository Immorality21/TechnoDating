@inherits LocalizedComponentBase
@inject IAuthStateService Auth
@inject NavigationManager Nav

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">TechnoDating</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                        <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> @L["Nav.Home"]
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="festivals">
                        <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> @L["Nav.Festivals"]
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="discover">
                        <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> @L["Nav.Discover"]
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="matches">
                        <span class="bi bi-heart-fill-nav-menu" aria-hidden="true"></span> @L["Nav.Matches"]
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="me">
                        <span class="bi bi-person-fill-nav-menu" aria-hidden="true"></span> @L["Nav.Profile"]
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <button class="nav-link btn btn-link text-start" @onclick="Logout">
                        <span class="bi bi-box-arrow-right-nav-menu" aria-hidden="true"></span> @L["Common.Logout"]
                    </button>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="login">
                        <span class="bi bi-box-arrow-in-right-nav-menu" aria-hidden="true"></span> @L["Nav.SignIn"]
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

@code {
    private async Task Logout()
    {
        await Auth.LogoutAsync();
        Nav.NavigateTo("/login", replace: true);
    }
}
